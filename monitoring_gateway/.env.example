# Backend API (ingest va gateway-monitors uchun)
GATEWAY_BACKEND_URL=https://medoraapi.cdcgroup.uz/api
# Ingest endpoint uchun kalit (backend MONITORING_INGEST_API_KEY bilan bir xil bo'lishi kerak)
GATEWAY_INGEST_API_KEY=monitoring-ingest-secret-change-in-production
# TCP monitorlar: device_id:host:port (vergul bilan ajratilgan)
# Masalan: K12_001:192.168.168.254:6006
GATEWAY_MONITORS=K12_01:192.168.168.254:6006
# HL7 (K12) default device_id — backend Device.serial_number ga mos
GATEWAY_HL7_DEFAULT_DEVICE_ID=K12_01
