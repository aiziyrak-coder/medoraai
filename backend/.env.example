# ================================================================
# Medora AI Backend — .env.example
# Nusxasini .env nomi bilan saqlang va HECH QACHON git ga commit qilmang!
# ================================================================

# ── Django ──────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database ─────────────────────────────────────────────────────
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3
# Production: PostgreSQL
# DB_ENGINE=django.db.backends.postgresql
# DB_USER=medora_user
# DB_PASSWORD=strong_password
# DB_HOST=localhost
# DB_PORT=5432

# ── CORS ─────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173

# ================================================================
# Azure AI Foundry (barcha 5 ta deployment)
# Azure Portal > Cognitive Services > Keys and Endpoint dan oling
# ================================================================
AZURE_OPENAI_ENDPOINT=https://medora-resource.cognitiveservices.azure.com/
AZURE_OPENAI_API_KEY=YOUR_AZURE_OPENAI_API_KEY
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Deployment names (Azure AI Foundry > Model deployments da ko'rsatilgan nomlar)
AZURE_DEPLOY_GPT4O=medora-gpt4o
AZURE_DEPLOY_DEEPSEEK=medora-deepseek
AZURE_DEPLOY_LLAMA=medora-llama
AZURE_DEPLOY_MISTRAL=medora-mistral
AZURE_DEPLOY_MINI=medora-mini

# ── Azure Speech Services (Medora-Jarvis) ─────────────────────────────────
# Azure Portal > Speech Services > Keys and Endpoint dan oling
AZURE_SPEECH_KEY=YOUR_AZURE_SPEECH_KEY_HERE
AZURE_SPEECH_REGION=swedencentral
AZURE_SPEECH_ENDPOINT=https://swedencentral.api.cognitive.microsoft.com/

# ── Telegram (to'lov cheklari — faqat server tomonda!) ──────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_PAYMENT_GROUP_ID=-1001234567890

# ── Redis (kesh va rate limiting) ───────────────────────────────
REDIS_URL=redis://localhost:6379/1

# ── Celery (ixtiyoriy — async task) ────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
