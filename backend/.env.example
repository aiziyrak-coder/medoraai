# ================================================================
# AiDoktor Backend  -  .env
# Domain: AiDoktorapi.ziyrak.org  |  IP: 20.82.115.71
# ================================================================
# Production: When DEBUG=False, SECRET_KEY must be set (app will not start with default).
# Create superuser in production: set ADMIN_PASSWORD env (no default allowed when DEBUG=False).

SECRET_KEY=your-very-secret-key-change-this-in-production
DEBUG=False
# Vergul bilan aniq domenlar (* qo‘ymang). Bo‘sh qoldirsangiz: fjsti/medora default ro‘yxati.
ALLOWED_HOSTS=fjsti.ziyrak.org,fjstiapi.ziyrak.org,medora.cdcgroup.uz,medoraapi.cdcgroup.uz,localhost,127.0.0.1

# Bir vaqtda faqat bitta qurilma (boshqa qurilmada logout qilinmaguncha yangi qurilmadan login yo'q)
# ENFORCE_SINGLE_DEVICE_LOGIN=True
# Superuser uchun istisno (admin panel): SINGLE_DEVICE_LOGIN_EXEMPT_SUPERUSER=True

# USD → UZS (obuna narxlari, serializer `price_monthly_uzs`; frontend `VITE_USD_TO_UZS_RATE` bilan mos)
USD_TO_UZS_RATE=12500

# Database (SQL — serverda saqlanadi, restart dan keyin ham o'chib ketmaydi)
DB_ENGINE=django.db.backends.sqlite3
# Serverda (masalan /root/medoraai): shu pathdan foydalaning; loyiha papkasi boshqa bo'lsa pathni o'zgartiring
DB_NAME=/root/medoraai/backend/db.sqlite3

# CORS — frontend domenlari (vergul bilan). Bo'sh qoldirsangiz settings.py dagi to'liq default ishlatiladi.
# FJSTI (fjsti.ziyrak.org) har doim backend kodida qo'shiladi; boshqa domenlarni shu yerga yozing.
CORS_ALLOWED_ORIGINS=https://fjsti.ziyrak.org,http://localhost:3000,http://localhost:5173

# HTTPS: True when Nginx serves SSL and sends X-Forwarded-Proto
SECURE_SSL_REDIRECT=True

# CSRF (ixtiyoriy): vergul bilan ajratilgan originlar; bo'sh qoldirsangiz settings dagi default ishlatiladi
# CSRF_TRUSTED_ORIGINS=https://fjsti.ziyrak.org,https://fjstiapi.ziyrak.org

# Frontend build (server-deploy.sh): API URL. FJSTI: https://fjstiapi.ziyrak.org/api
# VITE_API_BASE_URL=https://medoraapi.cdcgroup.uz/api

# в”Ђв”Ђ AI: faqat Gemini (Mukammal integratsiya) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Serverda majburiy: Google AI Studio dan kalit oling va shu yerga kiriting.
# Kalitni olish: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Gemini modellari (default: 2.5 barqaror; 3-preview uchun alohida yozing)
GEMINI_MODEL_FLASH=gemini-2.5-flash
GEMINI_MODEL_PRO=gemini-2.5-pro
GEMINI_MODEL_THINKING=gemini-2.5-flash

# в”Ђв”Ђ Azure Speech (ovoz, ixtiyoriy) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
AZURE_SPEECH_KEY=YOUR_AZURE_SPEECH_KEY
AZURE_SPEECH_REGION=swedencentral
AZURE_SPEECH_ENDPOINT=https://swedencentral.api.cognitive.microsoft.com/

# в”Ђв”Ђ Telegram в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_PAYMENT_GROUP_ID=YOUR_TELEGRAM_GROUP_ID

# в”Ђв”Ђ Redis (ixtiyoriy) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
REDIS_URL=

AI_MODEL_DEFAULT=gemini-2.5-pro

# Bitta login — faqat bitta qurilma (boshqa qurilmadan kirish bloklanadi, logoutdan keyin mumkin)
# ENFORCE_SINGLE_DEVICE_LOGIN=True
# Superuser ham cheklansin: False (default kodda). Faqat barcha qurilmalardan kirish kerak bo'lsa True qiling.
# SINGLE_DEVICE_LOGIN_EXEMPT_SUPERUSER=False
