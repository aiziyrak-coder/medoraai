# MedoraAI Backend — port 8001, loyiha /root/medoraai
# O'rnatish: sudo cp deploy/medoraai-backend-8001.service /etc/systemd/system/ && sudo systemctl daemon-reload && sudo systemctl enable --now medoraai-backend-8001

[Unit]
Description=MedoraAI Backend (Gunicorn, port 8001)
After=network.target

[Service]
Type=simple
User=root
Group=root
WorkingDirectory=/root/medoraai/backend
Environment=DJANGO_SETTINGS_MODULE=medoraai_backend.settings
# 400 Bad Request bartaraf: Host har doim qabul qilinsin (.env dan mustaqil)
Environment=ALLOWED_HOSTS=medora.cdcgroup.uz,medoraai.cdcgroup.uz,167.71.53.238,.cdcgroup.uz,localhost,127.0.0.1
ExecStart=/root/medoraai/backend/venv/bin/gunicorn \
    --bind 127.0.0.1:8001 \
    --workers 2 \
    --threads 4 \
    --timeout 180 \
    --access-logfile - \
    --error-logfile - \
    --log-level info \
    medoraai_backend.wsgi:application
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
