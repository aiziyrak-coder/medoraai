# ================================================================
# AiDoktor Frontend  -  .env.example
# Copy to .env.local or .env.production and fill values.
# All VITE_* vars are baked into the client bundle (public).
# ================================================================

# --- Required for API (auth, queue, patients, etc.) ---
# Backend API base URL (with /api). Dev: http://localhost:8000/api
VITE_API_BASE_URL=https://medoraapi.cdcgroup.uz/api

# --- AI: Gemini (frontend build va client-side AI) ---
# Build vaqtida bake qilinadi. Serverda .env da VITE_GEMINI_API_KEY=... qo'ying (build uchun).
VITE_GEMINI_API_KEY=

# --- Optional: Azure Speech (voice) ---
VITE_AZURE_SPEECH_REGION=swedencentral