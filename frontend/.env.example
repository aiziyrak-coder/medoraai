# ================================================================
# Medora AI Frontend — .env.example
# Copy to .env.local or .env.production and fill values.
# All VITE_* vars are baked into the client bundle (public).
# ================================================================

# --- Required for API (auth, queue, patients, etc.) ---
# Backend API base URL (with /api). Dev: http://localhost:8000/api
VITE_API_BASE_URL=https://medoraapi.ziyrak.org/api

# --- Optional: Azure AI Foundry (frontend fallback when backend is down) ---
# If set, client can call Azure directly; API key is public in bundle — restrict key permissions.
VITE_AZURE_OPENAI_ENDPOINT=
VITE_AZURE_OPENAI_API_KEY=
VITE_AZURE_API_VERSION=2024-12-01-preview
VITE_AZURE_DEPLOY_GPT4O=medora-gpt4o
VITE_AZURE_DEPLOY_MINI=medora-mini

# --- Optional: Azure Speech (voice) ---
VITE_AZURE_SPEECH_REGION=swedencentral
