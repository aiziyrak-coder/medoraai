# ================================================================
# Medora AI Frontend — .env.production
# Frontend: medora.ziyrak.org
# Backend:  medoraapi.ziyrak.org
# ================================================================

# Backend API URL — medoraapi.ziyrak.org
VITE_API_BASE_URL=https://medoraapi.ziyrak.org/api

# Azure AI Foundry (frontend fallback — backend offline bo'lganda)
VITE_AZURE_OPENAI_ENDPOINT=https://medora-resource.cognitiveservices.azure.com/
VITE_AZURE_OPENAI_API_KEY=YOUR_AZURE_OPENAI_KEY
VITE_AZURE_API_VERSION=2024-12-01-preview
VITE_AZURE_DEPLOY_GPT4O=medora-gpt4o
VITE_AZURE_DEPLOY_MINI=medora-mini

# Azure Speech
VITE_AZURE_SPEECH_REGION=swedencentral
