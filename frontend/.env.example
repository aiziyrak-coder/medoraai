# ================================================================
# AiDoktor Frontend  -  .env.example
# Copy to .env.local or .env.production and fill values.
# All VITE_* vars are baked into the client bundle (public).
# ================================================================

# --- Required for API (auth, queue, patients, etc.) ---
# Backend API base URL (with /api). Dev: http://localhost:8000/api
VITE_API_BASE_URL=https://fjstiapi.ziyrak.org/api

# Front va API bir xil domen (masalan fjsti.ziyrak.org/api) bo'lsa — health uchun API subdomen
# VITE_API_PUBLIC_HEALTH_URL=https://fjstiapi.ziyrak.org/health/

# Ixtiyoriy: faqat shu URL bilan health tekshiriladi
# VITE_HEALTH_CHECK_URL=https://fjstiapi.ziyrak.org/health/

# USD → UZS (backend `USD_TO_UZS_RATE` bilan bir xil qo'ying; oylik narxlarni so'mda ko'rsatish)
VITE_USD_TO_UZS_RATE=12500

# --- AI: Gemini (frontend build va client-side AI) ---
# Build vaqtida bake qilinadi. Serverda .env da VITE_GEMINI_API_KEY=... qo'ying (build uchun).
VITE_GEMINI_API_KEY=

# --- Optional: Azure Speech (voice) ---
VITE_AZURE_SPEECH_REGION=swedencentral

# --- Service Worker (PWA offline kesh) ---
# Productionda o'chiq (default). Yoqish: VITE_ENABLE_SW=true
# VITE_ENABLE_SW=true