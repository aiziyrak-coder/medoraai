# ================================================================
# Medora AI Frontend — .env.example
# Nusxasini .env.local nomi bilan saqlang va git ga commit QILMANG!
# ================================================================

# ── Backend API ──────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000/api
# Production:
# VITE_API_BASE_URL=https://medoraapi.cdcgroup.uz/api

# ================================================================
# Azure AI Foundry (Frontend Fallback)
# Asosiy AI chaqiruvlari BACKEND orqali amalga oshadi.
# Bu kalitlar faqat backend offline bo'lganda ishlatiladi.
# ================================================================
VITE_AZURE_OPENAI_ENDPOINT=https://medora-resource.cognitiveservices.azure.com/
VITE_AZURE_OPENAI_API_KEY=YOUR_AZURE_OPENAI_API_KEY
VITE_AZURE_API_VERSION=2024-12-01-preview

# Deployment names (backend bilan bir xil bo'lishi shart)
VITE_AZURE_DEPLOY_GPT4O=medora-gpt4o
VITE_AZURE_DEPLOY_MINI=medora-mini
